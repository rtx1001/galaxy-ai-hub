{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Galaxy AI Hub",
  "version": "0.1.4",
  "identifier": "com.admin.tauri-app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Galaxy AI Hub",
        "width": 1220,
        "height": 820,
        "center": true,
        "backgroundColor": "#0f1115",
        "minWidth": 480,
        "minHeight": 560
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
